# Get this from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=your_oauth_client_id_here.apps.googleusercontent.com

# Create a folder in Google Drive, share it with both Google accounts, then paste the folder ID here
# The folder ID is the last part of the folder URL: drive.google.com/drive/folders/THIS_PART
VITE_DRIVE_FOLDER_ID=your_shared_drive_folder_id_here
